{
  "name": "@mishu/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch rest.ts",
    "start": "bun rest.ts",
    "seed:dashboard": "bun scripts/seedDashboardData.ts",
    "build": "bun build rest.ts --target bun --outdir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "bun run typecheck",
    "test:agent-route": "bun test test/protocol.contract.test.ts",
    "test:sms-api": "bun test test/sms.api.test.ts",
    "cron": "bun cron.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "fastify": "^5.6.1",
    "ioredis": "^5.8.1",
    "mongoose": "^8.19.1",
    "node-cron": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^24.7.2",
    "typescript": "^5.9.3"
  }
}
